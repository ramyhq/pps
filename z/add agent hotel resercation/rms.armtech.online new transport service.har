">\r\n                <h5 class=\"modal-title\">Branches Switcher</h5>\r\n                <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\r\n            </div>\r\n\r\n            <div class=\"modal-body\">\r\n                <label class=\"form-label fw-bold mb-3\">\r\n                    Set your active branch\r\n                    <i class=\"fa fa-question-circle  text-muted\" data-bs-toggle=\"tooltip\" data-bs-custom-class=\"tooltip-inverse\" data-bs-placement=\"top\" title=\"You can manage the active branch only through the whole system\"></i>\r\n                </label>\r\n                <div>\r\n                \r\n   \r\n   \r\n                        <div class=\"form-check form-switch form-check-custom form-check-success form-check-solid  mb-3\">\r\n                                <input class=\"form-check-input h-20px w-30px\" type=\"radio\" name=\"branches\" checked value=\"90\" id=\"chkBranch_90\" />\r\n                            <label class=\"form-check-label\" for=\"chkBranch_90\">\r\n                                MainBranch\r\n                            </label>\r\n                        </div>\r\n                </div>\r\n                <hr class=\"border-gray-400\" />\r\n                <div class=\"row\">\r\n                    <div class=\"mb-3  col-md-4\">\r\n                        <label class=\"form-label required\" for=\"defaultBranch\">Default branch</label>\r\n                        <select class=\"form-control form-select m-input m-input--square\" name=\"defaultBranch\" id=\"defaultBranch\">\r\n                                <option selected=\"selected\" value=\"90\"> MainBranch</option>\r\n                        </select>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"modal-footer\">\r\n\r\n                <button type=\"button\" id=\"ChangeBranch\" class=\"btn btn-primary\"><i class=\"fa fa-save me-1\"></i> Save </button>\r\n                <button type=\"button\" class=\"btn btn-light\" data-bs-dismiss=\"modal\"><i class=\"fa fa-times me-1\"></i> Cancel</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n\r\n\r\n<!--Manage Favorites-->\r\n<div class=\"modal fade\" id=\"kt_modal_favorites\" tabindex=\"-1\" aria-hidden=\"true\">\r\n\t<div class=\"modal-dialog modal-lg  \">\r\n\t\t<div class=\"modal-content\">\r\n\t\t\t<div class=\"modal-header\">\r\n\t\t\t\t<h5 class=\"modal-title\"><i class=\"fa fa-star text-warning me-2 fa-lg\"></i>Manage favorites</h5>\r\n\t\t\t\t<button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"modal-body py-3\">\r\n\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t<div class=\"col-md-8\">\r\n\t\t\t\t\t\t<input type=\"text\" id=\"menuSearch\" class=\"form-control mb-5\" placeholder=\"Search...\">\r\n\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"col-md-4 mt-3\">\r\n\t\t\t\t\t\t<label>\r\n\t\t\t\t\t\t\t<input type=\"checkbox\" class=\"form-check-input\" id=\"filterFavorites\"> Show favorites only\r\n\t\t\t\t\t\t</label>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t\r\n\r\n\t\t\t\t<div class=\"table-responsive\">\r\n\t\t\t\t<table class=\"table table-hover table-row-bordered table-spaces py-2\" id=\"menuTable\">\r\n\t\t\t\t\t<thead class=\"fw-bold text-primary\">\r\n\t\t\t\t\t\t<tr class=\"border-bottom-1 border-primary\">\r\n\t\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t\t<th>Page</th>\r\n\t\t\t\t\t\t\t<th hidden></th>\r\n\t\t\t\t\t\t\t<th>Name</th>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t</thead>\r\n\t\t\t\t</table>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"modal-footer py-3\">\r\n\r\n\t\t\t\t<button type=\"button\" class=\"btn btn-primary\" data-bs-dismiss=\"modal\" id=\"SaveFavs\">Save</button>\r\n\t\t\t\t<button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Close</button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n\r\n\r\n<!--Manage Favorites-->\r\n<div class=\"modal fade\" id=\"kt_modal_searchRes\" tabindex=\"-1\" aria-hidden=\"true\">\r\n\t<div class=\"modal-dialog   modal-dialog-scrollable\">\r\n\t\t<div class=\"modal-content\">\r\n\t\t\t<div class=\"modal-header\">\r\n\t\t\t\t<h5 class=\"modal-title\">Search result for  <b class=\"highlight-search\" id=\"searchResultId\"></b></h5>\r\n\t\t\t\t<button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"modal-body\">\r\n\t\t\t\t<div id=\"res-searchReult\">\r\n\t\t\t\t\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n    <!-- end:: Page -->\r\n    <!-- begin::Scrolltop -->\r\n    <div id=\"kt_scrolltop\" class=\"scrolltop\" data-kt-scrolltop=\"true\">\r\n        <!--begin::Svg Icon | path: icons/duotune/arrows/arr066.svg-->\r\n        <span class=\"svg-icon\">\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\r\n                <rect opacity=\"0.5\" x=\"13\" y=\"6\" width=\"13\" height=\"2\" rx=\"1\" transform=\"rotate(90 13 6)\" fill=\"black\"></rect>\r\n                <path d=\"M12.5657 8.56569L16.75 12.75C17.1642 13.1642 17.8358 13.1642 18.25 12.75C18.6642 12.3358 18.6642 11.6642 18.25 11.25L12.7071 5.70711C12.3166 5.31658 11.6834 5.31658 11.2929 5.70711L5.75 11.25C5.33579 11.6642 5.33579 12.3358 5.75 12.75C6.16421 13.1642 6.83579 13.1642 7.25 12.75L11.4343 8.56569C11.7467 8.25327 12.2533 8.25327 12.5657 8.56569Z\" fill=\"black\"></path>\r\n            </svg>\r\n        </span>\r\n        <!--end::Svg Icon-->\r\n    </div>\r\n    <!-- end::Scrolltop -->\r\n    <!-- begin::Chat Bar -->\r\n\r\n<!-- begin::Quick Sidebar -->\r\n<div id=\"kt_drawer_chat\" class=\"bg-body drawer drawer-end\"\r\n     data-kt-drawer=\"true\"\r\n     data-kt-drawer-name=\"chat\"\r\n     data-kt-drawer-activate=\"true\"\r\n     data-kt-drawer-overlay=\"true\"\r\n     data-kt-drawer-width=\"{default:'300px', 'md': '500px'}\"\r\n     data-kt-drawer-direction=\"end\"\r\n     data-kt-drawer-toggle=\"#kt_drawer_chat_toggle\"\r\n     data-kt-drawer-close=\"#kt_drawer_chat_close\">\r\n    <!-- BEGIN FRIENDS -->\r\n    <div class=\"card card-flush w-100\" id=\"kt_drawer_chat_friends\">\r\n        <div class=\"card-header pt-7\" id=\"kt_chat_contacts_header\">\r\n            <div class=\"card-title\">\r\n                <form class=\"w-100 position-relative\" autocomplete=\"off\">\r\n                    <span class=\"svg-icon svg-icon-2 svg-icon-lg-1 svg-icon-gray-500 position-absolute top-50 ms-5 translate-middle-y\">\r\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\r\n                            <rect opacity=\"0.5\" x=\"17.0365\" y=\"15.1223\" width=\"8.15546\" height=\"2\" rx=\"1\" transform=\"rotate(45 17.0365 15.1223)\" fill=\"black\"></rect>\r\n                            <path d=\"M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z\" fill=\"black\"></path>\r\n                        </svg>\r\n                    </span>\r\n                    <input type=\"text\" id=\"ChatUserSearchUserName\" class=\"form-control form-control-solid px-15\" name=\"search\" value=\"\" placeholder=\"Filter/Add user\" data-bs-html=\"true\" data-bs-toggle=\"popover\" data-bs-placement=\"bottom\" data-bs-content=\"&#xD;&#xA;      Write only username for same tenant users, &lt;br&gt;&#xD;&#xA;      &lt;strong&gt;[tenancyName]\\[userName]&lt;/strong&gt; for other tenant&#x27;s users &lt;br&gt;&lt;br&gt;&#xD;&#xA;      for example: &lt;br&gt;&#xD;&#xA;      .\\admin -&gt; for host admin &lt;br&gt;&#xD;&#xA;      Test\\admin -&gt; for test tenant&#x27;s admin &lt;br&gt;&#xD;&#xA;      admin -&gt; for your tenant&#x27;s admin&#xD;&#xA;      \">\r\n                </form>\r\n            </div>\r\n            <div class=\"card-toolbar justify-content-end\">\r\n                <a href=\"javascript:;\" id=\"SearchChatUserButton\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary\" data-bs-toggle=\"tooltip\" title=\"Add friend\">\r\n                    <i class=\"fas fa-user-plus\"></i>\r\n                </a>\r\n                <a href=\"javascript:;\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary page-quick-sidebar-pinner\" data-bs-toggle=\"tooltip\" title=\"Pin\">\r\n                    <i class=\"fa fa-map-pin\" aria-label=\"Pin\"></i>\r\n                </a>\r\n                <a href=\"#\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary\" id=\"kt_drawer_chat_close\" data-bs-toggle=\"tooltip\" title=\"Close\">\r\n                    <i class=\"flaticon2-delete\"></i>\r\n                </a>\r\n            </div>\r\n        </div>\r\n        <div class=\"card-body pt-5\" id=\"kt_chat_contacts_body\">\r\n            <div class=\"scroll-y me-n5 pe-5 h-200px h-lg-auto chat-users\" data-kt-scroll=\"true\" data-kt-scroll-activate=\"{default: false, lg: true}\" data-kt-scroll-max-height=\"auto\" data-kt-scroll-dependencies=\"#kt_header, #kt_toolbar, #kt_footer, #kt_chat_contacts_header\" data-kt-scroll-wrappers=\"#kt_content, #kt_chat_contacts_body\" data-kt-scroll-offset=\"0px\">\r\n                <div id=\"friendListFriends\"></div>\r\n                <p id=\"EmptyFriendListInfo\">You don&#x27;t have any friends. Write a username to above input box and click &quot;Add Friend&quot; button.</p>\r\n            </div>\r\n            <div class=\"mt-20\">\r\n                <h5>Blocked Users</h5>\r\n                <div class=\"scroll-y me-n5 pe-5 h-200px h-lg-auto\">\r\n                    <div id=\"friendListBlockeds\"></div>\r\n                    <p id=\"EmptyBlockedFriendListInfo\">You don&#x27;t have any blocked users. In order to block a friend, select a friend and select block from actions dropdown.</p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <!-- END FRIENDS -->\r\n\r\n    <!-- BEGIN MESSAGES -->\r\n    <div class=\"card w-100 rounded-0 border-0 d-none\" id=\"kt_drawer_chat_messenger\">\r\n        <div class=\"card-header pe-5\" id=\"kt_drawer_chat_messenger_header\">\r\n            <div class=\"card-title\">\r\n                <div class=\"d-flex justify-content-center flex-column me-3\">\r\n                    <a href=\"#\" id=\"selectedChatUserName\" class=\"fs-4 fw-bolder text-gray-900 text-hover-primary me-1 mb-2 lh-1\"></a>\r\n                    <div class=\"mb-0 lh-1\" id=\"selectedChatUserStatus\">\r\n                        <span class=\"badge badge-success badge-circle w-10px h-10px me-1\"></span>\r\n                        <span class=\"fs-7 fw-bold text-muted\"></span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"card-toolbar\">\r\n                <a href=\"#\" id=\"kt_quick_sidebar_back\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary quick-sidebar-back d-none\" data-bs-toggle=\"tooltip\" title=\"Back\">\r\n                    <i class=\"fa fa-arrow-alt-circle-left\" aria-label=\"Back\"></i>\r\n                </a>\r\n                <a href=\"#\" id=\"liBanChatUser\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary quick-sidebar-back\" data-bs-toggle=\"tooltip\" title=\"Block user\">\r\n                    <i class=\"fa fa-ban\" aria-label=\"Block user\"></i>\r\n                </a>\r\n                <a href=\"#\" id=\"liUnbanChatUser\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary quick-sidebar-back\" data-bs-toggle=\"tooltip\" title=\"Unblock\">\r\n                    <i class=\"fa fa-check\" aria-label=\"Unblock\"></i>\r\n                </a>\r\n                <a href=\"#\" id=\"removeFriend\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary\" data-bs-toggle=\"tooltip\" title=\"Remove user\">\r\n                    <i class=\"fas fa-minus-circle\"></i>\r\n                </a>\r\n                <a href=\"#\" class=\"btn w-25px w-lg-40px h-25px h-lg-40px btn-icon btn-light btn-hover-primary\" id=\"kt_drawer_chat_close\">\r\n                    <i class=\"flaticon2-delete\"></i>\r\n                </a>\r\n            </div>\r\n        </div>\r\n        <div class=\"card-body py-0\">\r\n            <div id=\"kt_drawer_chat_messenger_body\" class=\"scroll-y me-n5 pe-5 pt-5\" data-kt-element=\"messages\" data-kt-scroll=\"true\" data-kt-scroll-activate=\"true\" data-kt-scroll-height=\"100%\" data-kt-scroll-dependencies=\"#kt_drawer_chat_messenger_header, #kt_drawer_chat_messenger_footer\" data-kt-scroll-wrappers=\"#kt_drawer_chat_messenger_body\" data-kt-scroll-offset=\"0px\">\r\n                <div class=\"messages\" id=\"UserChatMessages\">\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class=\"card-footer pt-4\" id=\"kt_drawer_chat_messenger_footer\">\r\n                        <form name=\"chatMessageForm\" id=\"chatMessageForm\" role=\"form\">\r\n                             <div id=\"files\" class=\"files\"></div>\r\n                            <textarea id=\"ChatMessage\" class=\"form-control form-control-flush mb-3\" rows=\"2\" data-kt-element=\"input\" placeholder=\"Type a message here...\" required maxlength=\"4096\"></textarea>\r\n                            <div class=\"d-flex flex-stack\">\r\n                                <div class=\"d-flex align-items-center me-2\">\r\n                                    <a href=\"#\" class=\"btn btn-sm btn-icon btn-active-light-primary me-1\" data-bs-toggle=\"tooltip\" title=\"File\">\r\n                                        <span class=\"fileinput-button\">\r\n                                            <i class=\"fas fa-paperclip fs-3 icon-lg\" ></i>\r\n                                            <input id=\"chatFileUpload\" type=\"file\" name=\"files\">\r\n                                        </span>\r\n                                    </a>\r\n                                    <a href=\"#\" class=\"btn btn-sm btn-icon btn-active-light-primary me-1\" data-bs-toggle=\"tooltip\" title=\"Image\">\r\n                                       <span class=\"fileinput-button\">\r\n                                           <i class=\"fas fa-camera-retro fs-3\"></i>\r\n                                           <input id=\"chatImageUpload\" type=\"file\" name=\"files\">\r\n                                       </span>\r\n                                   </a>\r\n                                   <a href=\"javascript:;\" class=\"btn btn-sm btn-icon btn-active-light-primary me-1\" id=\"btnLinkShare\"  data-bs-toggle=\"tooltip\" title=\"Link to current page\">\r\n                                       <span class=\"fileinput-button\">\r\n                                           <i class=\"fas fa-link fs-3\"></i>\r\n                                       </span>\r\n                                   </a>\r\n                                </div>\r\n                                <button class=\"btn btn-primary\" type=\"button\" data-kt-element=\"send\" id=\"SendChatMessageButton\">\r\n                                    Reply\r\n                                </button>\r\n                            </div>\r\n                        </form>\r\n                    </div>\r\n    </div>\r\n    \r\n</div>\r\n\r\n\r\n\r\n<script id=\"UserFriendTemplate\" type=\"x-tmpl-mustache\">\r\n    {{#.}}\r\n    <div class=\"d-flex py-4\">\r\n        <div class=\"d-flex align-items-center me-auto chat-user\" data-friend-tenant-id=\"{{friendTenantId}}\" data-friend-user-id=\"{{friendUserId}}\">\r\n    \t\t<div class=\"symbol symbol-45px symbol-circle\">\r\n    \t\t\t<img alt=\"Pic\" src=\"/Profile/GetFriendProfilePicture?userId={{friendUserId}}&tenantId={{friendTenantId}}\">\r\n    \t\t\t{{#isOnline}}\r\n                    <div class=\"symbol-badge bg-success start-100 top-100 border-4 h-15px w-15px ms-n2 mt-n2\"></div>\r\n                {{/isOnline}}\r\n                {{^isOnline}}\r\n                    <div class=\"symbol-badge bg-secondary start-100 top-100 border-4 h-15px w-15px ms-n2 mt-n2\"></div>\r\n                {{/isOnline}}\r\n    \t\t</div>\r\n    \t\t<div class=\"ms-5\">\r\n    \t\t\t<a href=\"#\" class=\"fs-5 fw-bolder text-gray-900 text-hover-primary mb-2\">{{friendUserName}}</a>\r\n    \t\t\t<div class=\"fw-bold text-muted\">\r\n    \t\t\t    {{friendTenancyName}}\r\n                    {{^friendTenancyName}}\r\n                    Host\r\n                    {{/friendTenancyName}}\r\n    \t\t\t</div>\r\n    \t\t</div>\r\n    \t</div>\r\n    \t<div class=\"d-flex align-items-center me-5 message-count\" data-friend-tenant-id=\"{{friendTenantId}}\" data-friend-user-id=\"{{friendUserId}}\">\r\n    \t\t{{#unreadMessageCount}}\r\n            <span class=\"badge badge-circle badge-warning\">\r\n                {{unreadMessageCount}}\r\n            </span>\r\n            {{/unreadMessageCount}}\r\n            {{^unreadMessageCount}}\r\n            <span class=\"badge badge-circle badge-warning d-none\">\r\n                {{unreadMessageCount}}\r\n            </span>\r\n            {{/unreadMessageCount}}\r\n    \t</div>\r\n    </div>\r\n    {{/.}}\r\n</script>\r\n\r\n<script id=\"UserChatMessageTemplate\" type=\"x-tmpl-mustache\">\r\n    {{#.}}\r\n    {{^isIn}}\r\n     <div class=\"d-flex justify-content-start mb-5\">\r\n         <div class=\"d-flex flex-column align-items-start\">\r\n             <div class=\"d-flex align-items-center mb-2\">\r\n                 <div class=\"symbol symbol-35px symbol-circle\">\r\n                     <img alt=\"Pic\" src=\"/Profile/GetProfilePicture\">\r\n                 </div>\r\n                 <div class=\"ms-3\">\r\n                     <a href=\"#\" class=\"fs-5 fw-bolder text-gray-900 text-hover-primary me-1\">\r\n                        {{shownUserName}}\r\n                     </a>\r\n                     <time class=\"text-muted fs-7 mb-1 timeago\" datetime=\"{{creationTime}}\"></time> {{{readStateCheck}}}\r\n                 </div>\r\n             </div>\r\n             <div class=\"p-5 rounded bg-light-info text-dark fw-bold mw-lg-400px text-start\" data-kt-element=\"message-text\">\r\n                 {{{formattedMessage}}}\r\n             </div>\r\n         </div>\r\n     </div>\r\n    {{/isIn}}\r\n    {{#isIn}}\r\n    <div class=\"d-flex justify-content-end mb-10\">\r\n        <div class=\"d-flex flex-column align-items-end\">\r\n            <div class=\"d-flex align-items-center mb-2\">\r\n                <div class=\"me-3\">\r\n                    <time class=\"text-muted fs-7 mb-1 timeago\" datetime=\"{{creationTime}}\"></time> {{{readStateCheck}}}\r\n                    <a href=\"#\" class=\"fs-5 fw-bolder text-gray-900 text-hover-primary ms-1\">\r\n                        {{shownUserName}}\r\n                    </a>\r\n                </div>\r\n                <div class=\"symbol symbol-35px symbol-circle\">\r\n                    <img alt=\"Pic\" src=\"/Profile/GetFriendProfilePicture?userId={{targetUserId}}&tenantId={{targetTenantId}}\">\r\n                </div>\r\n            </div>\r\n            <div class=\"p-5 rounded bg-light-primary text-dark fw-bold mw-lg-400px text-end\" data-kt-element=\"message-text\">\r\n                {{{formattedMessage}}}\r\n            </div>\r\n        </div>\r\n    </div>\r\n    {{/isIn}}\r\n    {{/.}}\r\n</script>\r\n    <!-- end::Chat Bar -->\r\n    <!-- begin::Theme Selection Panel -->\r\n    <!-- end::Theme Selection Panel -->\r\n    <!--begin::Base Scripts -->\r\n    <script src=\"/view-resources/Areas/App/Views/_Bundles/app-layout-libs.min.js?v=mWmGwfcgnOeNxhK1401xzQVVxRdsI__RdzOxJhI0dEc\"></script>\r\n    <script src=\"/view-resources/Areas/App/Views/_Bundles/default-scripts.bundle.min.js?v=ynIGdiWrbl6LXPwV1JLsG7sjLcMuTZYgmT7HL35wzLc\"></script>\r\n\r\n    <!-- Dynamic scripts of ABP system (They are created on runtime and can not be bundled) -->\r\n    <script src=\"/common/scripts/AbpServiceProxies.min.js?v=Lm1FV_rPUvK17jB_yW_yTui8mfXp2BiMCbKp8d8Uu_0\" type=\"text/javascript\"></script>\r\n        <script src=\"/AbpScripts/GetScripts?v=314097dded4d4532821b7015a4c4b1b11.2.0.85\" type=\"text/javascript\"></script>\r\n    <script type=\"text/javascript\">\r\n        abp.localization.currentCulture = $.extend({}, abp.localization.currentCulture, { displayNameEnglish: 'English' });\r\n        abp.localization.defaultSourceName = 'RMS';\r\n        moment.locale('en'); //Localizing moment.js\r\n        Object.defineProperty(String.prototype, \"format\", {\r\n            value: function format(strArr) {\r\n                if (!Array.isArray(strArr))\r\n                    strArr = [strArr];\r\n                var res = this;\r\n                for (var i = 0; i < strArr.length; i++) {\r\n                    dRegex = new RegExp(\"\\\\{\" + i + \"\\\\}\", \"g\");\r\n                    res = res.replace(dRegex, strArr[i]);\r\n                }\r\n                return res;\r\n            },\r\n            writable: true,\r\n            configurable: true,\r\n        });\r\n    </script>\r\n\r\n    <script src=\"/view-resources/Areas/App/Views/_Bundles/signalr.bundle.min.js?v=Y0ZP86KlzYssCPhGoDoCDgZIl4jQdDpprAGhqUyBOJQ\"></script>\r\n    <script src=\"/view-resources/areas/app/views/common/crypto-js.min.js?v=GqFmy7uHIlcW24E3Obs9k8y6AtAKsw9VxZ1FrLpQn-U\"></script>\r\n    <script>\r\n        var Cryptokey = \"0ead70a0538d4604b3704a0554a89a698a20765f8ae1cd533a4fa460484ada42\";\r\n    </script>\r\n    <script src=\"/view-resources/areas/app/views/common/SimpleStringCipher.min.js?v=er9mqjU29j