\n<option value=\"133\"></option>\r\n<option value=\"134\">Armenian</option>\r\n<option value=\"135\"></option>\r\n<option value=\"136\"></option>\r\n<option value=\"137\">Afghan</option>\r\n<option value=\"138\">Cameroonian</option>\r\n<option value=\"139\">UK</option>\r\n<option value=\"140\"></option>\r\n<option value=\"141\">Chadian</option>\r\n<option value=\"142\"></option>\r\n<option value=\"143\"></option>\r\n<option value=\"144\">Monacan</option>\r\n<option value=\"145\">Ugandan</option>\r\n<option value=\"146\">Alandic</option>\r\n<option value=\"147\">Andorran</option>\r\n<option value=\"148\">Antarctic</option>\r\n<option value=\"149\">Antiguan</option>\r\n<option value=\"150\">Argentina</option>\r\n<option value=\"151\">Aruban</option>\r\n<option value=\"152\">Barbadian</option>\r\n<option value=\"153\">Beninese</option>\r\n<option value=\"154\">Bermudian</option>\r\n<option value=\"155\">Bhutanese</option>\r\n<option value=\"156\">Bolivian</option>\r\n<option value=\"157\">British Indian Ocean Territory citizen</option>\r\n<option value=\"158\">Chilean</option>\r\n<option value=\"159\">Bulgarian</option>\r\n<option value=\"160\">Cayman Islander</option>\r\n<option value=\"161\">Central African</option>\r\n<option value=\"163\">Christmas Island</option>\r\n<option value=\"164\">Cocos Island</option>\r\n<option value=\"165\">Colombian</option>\r\n<option value=\"166\">Congolese (Congo)</option>\r\n<option value=\"167\">Costa Rican</option>\r\n<option value=\"168\">Congolese (DRC)</option>\r\n<option value=\"169\">Ethiopia </option>\r\n<option value=\"170\"></option>\r\n<option value=\"171\">Basotho</option>\r\n<option value=\"172\">Bissau-Guinean</option>\r\n<option value=\"173\">Ecuadorian</option>\r\n<option value=\"174\">Ghanaian</option>\r\n<option value=\"175\">Greenlander</option>\r\n<option value=\"176\">Nepalese</option>\r\n<option value=\"177\">Saint Helenian</option>\r\n<option value=\"178\">Salvadorean</option>\r\n<option value=\"179\">Surinamese</option>\r\n<option value=\"180\">United States Minor Outlying Islands</option>\r\n</select>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t\t<div class=\"col-md-4 mb-3 \">\r\n\t\t\t\t\t\t\t\t<label class=\"form-label\" for=\"\">Terms &amp; conditions</label>\r\n\r\n\t\t\t\t\t\t\t\t<select class=\"form-control\" id=\"termsAndCondionId\" name=\"termsAndCondionId\"><option value=\"\">Select</option>\r\n<option value=\"89\">Genral Policy</option>\r\n<option value=\"98\">Train</option>\r\n<option value=\"99\">Ramadan</option>\r\n<option value=\"100\">Visa</option>\r\n<option value=\"101\">Hajj</option>\r\n<option value=\"129\">HANDLING</option>\r\n</select>\r\n\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"col-md-4 mb-3\">\r\n\t\t\t\t\t\t\t\t<div class=\"form-group\">\r\n\t\t\t\t\t\t\t\t\t<label class=\"form-label\" for=\"ReservationTag\">Tags</label>\r\n\r\n\t\t\t\t\t\t\t\t\t<select id=\"ReservationTag\" class=\"form-control select2-tagging\" data-control=\"select2\" multiple=\"multiple\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<option value=\"156\">Hajj</option>\r\n\t\t\t\t\t\t\t\t\t</select>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\t\t\t\t\t<label class=\"form-label\" for=\"\">File No.</label>\r\n\t\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control\" id=\"FileNo\" />\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\t\t\t\t\t<label class=\"form-label\" for=\"\">Reservation remarks</label>\r\n\t\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control\" id=\"ReservationRemarks\" />\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t\t<div class=\"col-md-4 mb-3\">\r\n\t\t\t\t\t\t\t\t<label class=\"form-label\">Supervisor name</label>\r\n\t\t\t\t\t\t\t\t<input class=\"form-control\" type=\"text\" id=\"SupervisorName\" />\r\n\t\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t\t<div class=\"col-md-3 mb-3\">\r\n\t\t\t\t\t\t\t\t<div id=\"mobile-container\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"mobile-field mb-2\">\r\n\t\t\t\t\t\t\t\t\t\t\t<label for=\"mobile_0\" class=\"form-label\">Supervisor mobile</label>\r\n\t\t\t\t\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control w-90\" id=\"mobile_0\" name=\"mobile_0\" />\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"col-md-1 mb-3  mt-label\">\r\n\t\t\t\t\t\t\t\t<button type=\"button\" class=\"btn btn-link py-1 d-inline-block\" id=\"add-mobile-btn\">\r\n\t\t\t\t\t\t\t\t\t<i class=\"fa fa-plus\"></i>Add\r\n\t\t\t\t\t\t\t\t</button>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t\t<div class=\"col-md-12\">\r\n\t\t\t\t\t\t\t\t<!-- link to MOFA -->\r\n\t\t\t\t\t\t\t\t<div class=\"form-check mt-3\">\r\n\t\t\t\t\t\t\t\t\t<input class=\"form-check-input\" type=\"checkbox\" id=\"linkToMofaCheck\" >\r\n\t\t\t\t\t\t\t\t\t<label class=\"form-check-label fw-bold text-info\" for=\"linkToMofaCheck\">\r\n\t\t\t\t\t\t\t\t\t\t<em class=\"fa fa-users me-1\"></em>\r\n\t\t\t\t\t\t\t\t\t\tLink to group\r\n\t\t\t\t\t\t\t\t\t</label>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- MOFA Panels (hidden by default) -->\r\n\t\t\t\t<input type=\"hidden\" id=\"groupCounter\" value=\"1\" />\r\n\t\t\t\t<input type=\"hidden\" id=\"mobileCounter\" value=\"1\" />\r\n\r\n\t\t\t\t<!-- Groups Panel -->\r\n\t\t\t\t<div class=\"panel mt-3\" id=\"GroupPanels\" style=\"display:none\">\r\n\t\t\t\t\t\t\t\t<div class=\"panel-header text-primary\">\r\n\t\t\t\t\t\t\t\t\tGroups\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"panel-body\">\r\n\t\t\t\t\t\t\t\t\t<!--travel details-->\r\n\t\t\t\t\t\t\t\t\t<div>\r\n\t\t\t\t\t\t\t\t\t\t<h4>Travel details</h4>\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\