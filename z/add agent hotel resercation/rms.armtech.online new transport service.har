ion date</label>\r\n\t\t\t<input type=\"text\" placeholder=\"dd/mm/yyyy\" class=\"form-control date-picker\" id=\"ProviderOptionDate-picker\" name=\"ProviderOptionDate-picker\" value=\"\" autocomplete=\"off\" data-autoupdate=\"false\" />\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<div class=\"row \">\r\n\t\t<div class=\"col-md-4 mb-3 mt-3\">\r\n\t\t\t<div class=\"form-check\">\r\n\t\t\t\t<input class=\"form-check-input\" type=\"checkbox\" id=\"chk_PricingPerTrip\"  />\r\n\t\t\t\t<label class=\"form-check-label\" for=\"chk_PricingPerTrip\">\r\n\t\t\t\t\tSet Sale and Cost per each Trip\r\n\t\t\t\t\t<i class=\"fa fa-question-circle text-muted\" data-bs-toggle=\"tooltip\" data-bs-custom-class=\"tooltip-inverse\" data-bs-placement=\"top\" title=\"Apply pricing for each trip instead of for the whole transportation service\"></i>\r\n\t\t\t\t</label>\r\n\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n\t<div id=\"PricingAllTransportation\" class=\"\">\r\n\t\t<div class=\"table-responsive col-xl-8\">\r\n\t\t\t<table class=\"table table-striped table-row-bordered border align-middle mt-2\">\r\n\t\t\t\t<colgroup>\r\n\t\t\t\t\t<col style=\"width:10%\">\r\n\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t</colgroup>\r\n\t\t\t\t<thead>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t<th>Per item</th>\r\n\t\t\t\t\t\t<th>Price</th>\r\n\t\t\t\t\t\t<th>VAT</th>\r\n\t\t\t\t\t\t<th>Total</th>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</thead>\r\n\t\t\t\t<tbody>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<td class=\"fw-bold\">Sale</td>\r\n\t\t\t\t\t\t<td class=\"py-0\">\r\n\t\t\t\t\t\t\t<input class=\"form-control\" type=\"number\" value=\"0\" min=\"0\" id=\"SaleInputPerService\" name=\"SaleInputPerService\" />\r\n\t\t\t\t\t\t\t<input class=\"form-control\" value=\"15.00\" type=\"hidden\" id=\"SaleVatRate\" name=\"SaleVatRate\" />\r\n\t\t\t\t\t\t\t<input class=\"form-control\" value=\"0\" type=\"hidden\" id=\"ReservationId\" name=\"ReservationId\" />\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td class=\"py-0 view-disabled\">\r\n\t\t\t\t\t\t\t<p id=\"SalePerItemPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"SalePerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"SaleVatPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"TotalSalePerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<td class=\"fw-bold\">Cost</td>\r\n\t\t\t\t\t\t<td class=\"py-0\">\r\n\t\t\t\t\t\t\t<input class=\"form-control\" type=\"number\" id=\"CostInputPerService\" name=\"CostInputPerService\" value=\"0\" min=\"0\" />\r\n\t\t\t\t\t\t\t<input class=\"form-control\" value=\"15.00\" type=\"hidden\" id=\"CostVatRate\" name=\"CostVatRate\" />\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td class=\"py-0 view-disabled\">\r\n\t\t\t\t\t\t\t<p id=\"CostPerItemPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"CostPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"CostVatPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"TotalCostPerService\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</tbody>\r\n\t\t\t</table>\r\n\t\t</div>\r\n\t\t<div class=\"d-flex flex-wrap gap-4 mb-3\">\r\n\t\t\t<!-- Prices do not include tax -->\r\n\t\t\t<label class=\"form-check form-check-custom mb-0\">\r\n\t\t\t\t<input type=\"checkbox\" class=\"form-check-input\" id=\"IsIncludeSaleVatPerService\" value=\"false\"  />\r\n\t\t\t\t<span class=\"form-check-label text-nowrap\">Prices do not include VAT</span>\r\n\t\t\t</label>\r\n\r\n\t\t\t<!-- Don't apply VAT to cost -->\r\n\t\t\t<label class=\"form-check form-check-custom mb-0\" style=\"display:\">\r\n\t\t\t\t<input id=\"IsApplyCostVatPerService\" name=\"IsApplyCostVat\" type=\"checkbox\" class=\"form-check-input\" value=\"0\" >\r\n\t\t\t\t<span id=\"lbl_DontApplyVAT\" class=\"form-check-label\">Don&#x27;t apply VAT to cost</span>\r\n\t\t\t</label>\r\n\t\t</div>\r\n\t</div>\r\n\t<div id=\"PricingPerTrip\" class=\"\">\r\n\t\t<div class=\"table-responsive col-xl-8\">\r\n\t\t\t<table class=\"table table-striped table-row-bordered border align-middle mt-2\">\r\n\t\t\t\t<colgroup>\r\n\t\t\t\t\t<col style=\"width:25%\">\r\n\t\t\t\t\t<col style=\"width:25%\">\r\n\t\t\t\t\t<col style=\"width:25%\">\r\n\t\t\t\t\t<col style=\"width:25%\">\r\n\t\t\t\t</colgroup>\r\n\t\t\t\t<thead>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t<th>Price</th>\r\n\t\t\t\t\t\t<th>VAT</th>\r\n\t\t\t\t\t\t<th>Total</th>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</thead>\r\n\t\t\t\t<tbody>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<td class=\"fw-bold\">Sale</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"SalePerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"SaleVatPerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p class=\"fw-bold\" id=\"TotalSalePerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t<td class=\"fw-bold\">Cost</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"CostPerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p id=\"CostVatPerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p class=\"fw-bold\" id=\"TotalCostPerTrip\">0</p>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</tbody>\r\n\t\t\t</table>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<hr class=\"border-gray-400 mb-4\">\r\n\t<h4>Trips details</h4>\r\n\t<div class=\"row\">\r\n\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t<label class=\"form-label required d-block mb-2\">Route Selection</label>\r\n\t\t\t<div class=\"form-check\">\r\n\t\t\t\t<input class=\"form-check-input\" type=\"radio\" name=\"routeType\" id=\"routeCustom\" value=\"custom\" checked>\r\n\t\t\t\t<label class=\"form-check-label\" for=\"routeCustom\">\r\n\t\t\t\t\t<i class=\"fa fa-cogs\"></i> Custom Route\r\n\t\t\t\t</label>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t<div class=\"form-check mt-label\">\r\n\t\t\t\t<input class=\"form-check-input\" type=\"radio\" name=\"routeType\" id=\"routeService\" value=\"service\">\r\n\t\t\t\t<label class=\"form-check-label\" for=\"routeService\">\r\n\t\t\t\t\t<i class=\"fas fa-map-location-dot\"></i> Service Route\r\n\t\t\t\t</label>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"col-md-3 mb-3 d-none form-select2\" id=\"serviceRouteSelect\">\r\n\t\t\t<label class=\"form-label required\">Service Route</label>\r\n\t\t\t<select class=\"form-control form-select select2\" id=\"RouteId\" name=\"RouteId\" data-control=\"select2\">\r\n\t\t\t\t<option value=\"0\">Select</option>\r\n\t\t\t</select>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<div class=\"row pb-3\">\r\n\t\t<div class=\"col-md-4 mb-3\">\r\n\t\t\t<label class=\"form-label form-select2\">Vehicle</label>\r\n\t\t\t<select class=\"form-control form-select\" id=\"VehicleId\" name=\"VehicleId\" data-control=\"select2\">\r\n\t\t\t\t<option value=\"0\">Select</option>\r\n\t\t\t\t\t<option value=\"75\">Bus - BUS</option>\r\n\t\t\t\t\t<option value=\"76\">Bus - 49</option>\r\n\t\t\t\t\t<option value=\"77\">GMC - GMC</option>\r\n\t\t\t\t\t<option value=\"78\">Coaster - COASTAR</option>\r\n\t\t\t\t\t<option value=\"79\">Train - SAR</option>\r\n\t\t\t\t\t<option value=\"80\">Hiase - PRIVETE</option>\r\n\t\t\t\t\t<option value=\"110\">STARIA - STARIA - 4 Seats</option>\r\n\t\t\t\t\t<option value=\"111\">STARIA - Staria  - 7 Seats</option>\r\n\t\t\t\t\t<option value=\"196\">TAXI - Camry  - 4 Seats</option>\r\n\t\t\t\t\t<option value=\"200\">PICK UP LUGGAGE - TRUCK</option>\r\n\t\t\t\t\t<option value=\"217\">TAXI - Lexus car - 4 Seats</option>\r\n\t\t\t\t\t<option value=\"237\">Bus -  Bus VIP  - 28 Seats</option>\r\n\t\t\t</select>\r\n\t\t</div>\r\n\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t<label class=\"form-label\">Quantity</label>\r\n\t\t\t<input class=\"form-control\" min=\"0\" id=\"Quantity\" name=\"Quantity\" type=\"number\" />\r\n\t\t</div>\r\n\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t<label class=\"form-label\">PAX</label>\r\n\t\t\t<input class=\"form-control\" min=\"0\" id=\"NoOfPAX\" name=\"NoOfPAX\" type=\"number\" />\r\n\t\t</div>\r\n\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t<button class=\"btn btn-outline btn-outline-primary btn-sm mt-label\" id=\"ApplyToAll-btn\">Apply to all</button>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\r\n\r\n\r\n\t<!-- trip -->\r\n\t<div class=\"mt-2 d-none\" id=\"cloneTrip\">\r\n\t\t<div class=\"card border border-gray-400 accordion accordion-icon-toggle reservation-accordion\" id=\"acc_trip1\">\r\n\t\t\t<div class=\"card-header px-2 border-0\">\r\n\t\t\t\t<h3 class=\"card-title fs-5 text-primary accordion-header d-flex\" data-bs-toggle=\"collapse\" data-bs-target=\"#trip1_collapse\" aria-expanded=\"false\">\r\n\t\t\t\t\t<span class=\"accordion-icon\">\r\n\t\t\t\t\t\t<span class=\"svg-icon svg-icon-4\"><i class=\"fa fa-caret-down text-primary\"></i></span>\r\n\t\t\t\t\t</span>\r\n\t\t\t\t\t<i class=\"fa fa-bus text-primary fs-3 mx-2\"></i>\r\n\t\t\t\t\tTrip <span class=\"mx-2 trip-number\">(#T-1)</span>\r\n\t\t\t\t</h3>\r\n\t\t\t\t<div class=\"card-toolbar\">\r\n\t\t\t\t\t<button type=\"button\" class=\"btn btn-link p-0 text-danger btn-delete-trip\" title=\"Delete\">\r\n\t\t\t\t\t\t<i class=\"fa fa-trash text-danger\"></i>\r\n\t\t\t\t\t</button>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div id=\"trip1_collapse\" class=\"collapse show\" data-bs-parent=\"#acc_trip1\">\r\n\t\t\t\t<div class=\"px-2 pb-5\">\r\n\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\t\t\t\t<input class=\"form-control TripId\" value=\"0\" type=\"hidden\" id=\"TripId\" name=\"TripId\" />\r\n\t\t\t\t\t\t\t<input class=\"form-control TripIndex\" value=\"-1\" type=\"hidden\" id=\"Index\" name=\"Index\" />\r\n\t\t\t\t\t\t\t<label class=\"form-label\">Type</label>\r\n\t\t\t\t\t\t\t<select class=\"form-control form-select TripType\" id=\"TripType\" name=\"TripType\">\r\n\t\t\t\t\t\t\t\t<option value=\"0\">Select</option>\r\n\t\t\t\t\t\t\t\t<option value=\"1\">Arrival</option>\r\n\t\t\t\t\t\t\t\t<option value=\"2\">Internal</option>\r\n\t\t\t\t\t\t\t\t<option value=\"3\">Departure</option>\r\n\t\t\t\t\t\t\t</select>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2\">\r\n\t\t\t\t\t\t\t<label class=\"form-label required\">From</label>\r\n\t\t\t\t\t\t\t<select class=\"form-control form-select select2-destination TripFromDestinationId\">\r\n\t\t\t\t\t\t\t\t<option value=\"0\">Destination</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"232\">MED TRAIN</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"233\">MED APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"234\">MED HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"235\">MED MAZARAT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"240\">MAK HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"241\">MAK TRAIN</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"242\">MAK MAZARAT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"243\">JED APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"244\">JED HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"245\">JED TOUR</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"246\">AL Ula</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"247\">AL Baidaa</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"248\">Badr</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"249\">AL Taif</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"288\">JED TRAIN AL Salmaniya</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"289\">JED TRAIN APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"290\">Tan&#x27;im</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"311\">ISLAMIC UNIVERSITY</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"314\">ALBAIDAA</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"373\">Miqat Al-Madina</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"378\">Cairo APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"379\">Cairo HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"510\">Abyar Ali </option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"538\">AlTaif Al-Hada   </option>\r\n\t\t\t\t\t\t\t</select>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2 mt-label\">\r\n\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control TripFromPlace\" placeholder=\"Place\" id=\"FromPlace\" name=\"FromPlace\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2\">\r\n\t\t\t\t\t\t\t<label class=\"form-label required\">To</label>\r\n\t\t\t\t\t\t\t<select class=\"form-control form-select select2-destination TripToDestinationId\">\r\n\t\t\t\t\t\t\t\t<option value=\"0\">Destination</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"232\">MED TRAIN</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"233\">MED APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"234\">MED HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"235\">MED MAZARAT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"240\">MAK HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"241\">MAK TRAIN</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"242\">MAK MAZARAT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"243\">JED APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"244\">JED HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"245\">JED TOUR</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"246\">AL Ula</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"247\">AL Baidaa</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"248\">Badr</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"249\">AL Taif</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"288\">JED TRAIN AL Salmaniya</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"289\">JED TRAIN APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"290\">Tan&#x27;im</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"311\">ISLAMIC UNIVERSITY</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"314\">ALBAIDAA</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"373\">Miqat Al-Madina</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"378\">Cairo APT</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"379\">Cairo HTL</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"510\">Abyar Ali </option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"538\">AlTaif Al-Hada   </option>\r\n\t\t\t\t\t\t\t</select>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2 mt-label\">\r\n\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control TripToPlace\" placeholder=\"Place\" id=\"ToPlace\" name=\"ToPlace\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-label required\">Date</label>\r\n\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control TripDate\" placeholder=\"dd/MM/yyyy\" data-autoupdate=\"false\" id=\"TripDate-picker\" name=\"TripDate-picker\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2 mb-3 flatpicker-container\">\r\n\t\t\t\t\t\t\t<label class=\"form-label required\">Time</label>\r\n\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control TripTime flatPicker\" id=\"TripTime\" name=\"TripTime\" placeholder=\"HH:mm\" autocomplete=\"off\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-2 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-label required\">Vehicle</label>\r\n\t\t\t\t\t\t\t<select class=\"form-control form-select select2-vehicle TripVehicleId\">\r\n\t\t\t\t\t\t\t\t<option value=\"0\">Select</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"75\">Bus - BUS</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"76\">Bus - 49</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"77\">GMC - GMC</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"78\">Coaster - COASTAR</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"79\">Train - SAR</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"80\">Hiase - PRIVETE</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"110\">STARIA - STARIA - 4 Seats</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"111\">STARIA - Staria  - 7 Seats</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"196\">TAXI - Camry  - 4 Seats</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"200\">PICK UP LUGGAGE - TRUCK</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"217\">TAXI - Lexus car - 4 Seats</option>\r\n\t\t\t\t\t\t\t\t\t<option value=\"237\">Bus -  Bus VIP  - 28 Seats</option>\r\n\t\t\t\t\t\t\t</select>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-1 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-label text-nowrap required\">Quantity</label>\r\n\t\t\t\t\t\t\t<input type=\"number\" class=\"form-control TripQuantity Quantity\" name=\"Quantity\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-1 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-label text-nowrap\">PAX</label>\r\n\t\t\t\t\t\t\t<input type=\"number\" class=\"form-control TripNoOfPAX\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"col-md-4 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-label\">Trip notes</label>\r\n\t\t\t\t\t\t\t<input type=\"text\" class=\"form-control TripNotes\" id=\"TripNotes\" name=\"TripNotes\" placeholder=\"Drive name, Driver phone, Flight no. ...\">\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<!--Sale & Cost -->\r\n\t\t\t\t\t<div class=\"SaleCostByTrip \">\r\n\t\t\t\t\t\t<div class=\"table-responsive col-xl-8\">\r\n\t\t\t\t\t\t\t<table class=\"table table-striped table-row-bordered border align-middle mt-2\">\r\n\t\t\t\t\t\t\t\t<colgroup>\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:10%\">\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t\t\t\t\t<col style=\"width:18%\">\r\n\t\t\t\t\t\t\t\t</colgroup>\r\n\t\t\t\t\t\t\t\t<thead>\r\n\t\t\t\t\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t\t\t\t\t<th></th>\r\n\t\t\t\t\t\t\t\t\t\t<th>Per item</th>\r\n\t\t\t\t\t\t\t\t\t\t<th>Price</th>\r\n\t\t\t\t\t\t\t\t\t\t<th>VAT</th>\r\n\t\t\t\t\t\t\t\t\t\t<th>Total</th>\r\n\t\t\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t\t</thead>\r\n\t\t\t\t\t\t\t\t<tbody>\r\n\t\t\t\t\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"fw-bold\">Sale</td>\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"py-0\">\r\n\t\t\t\t\t\t\t\t\t\t\t<input class=\"form-control TripSaleInput\" type=\"number\" value=\"0\" min=\"0\" id=\"TripSaleInput\" name=\"TripSaleInput\" />\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"py-0 view-disabled\">\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripSalePerItem\" id=\"TripSalePerItem\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripSale\" id=\"TripSale\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripSaleVat\" id=\"TripSaleVat\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripTotalSale\" id=\"TripTotalSale\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t\t\t<tr class=\"border\">\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"fw-bold\">Cost</td>\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"py-0\">\r\n\t\t\t\t\t\t\t\t\t\t\t<input class=\"form-control TripCostInput\" type=\"number\" id=\"TripCostInput\" name=\"TripCostInput\" value=\"0\" min=\"0\" />\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td class=\"py-0 view-disabled\">\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripCostPerItem\" id=\"TripCostPerItem\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripCost\" id=\"TripCost\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripCostVat\" id=\"TripCostVat\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"mt-2 TripTotalCost\" id=\"TripTotalCost\"></p>\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t\t</tbody>\r\n\t\t\t\t\t\t\t</table>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Checkboxes -->\r\n\t\t\t\t\t\t<div class=\"d-flex flex-wrap gap-4 mb-3\">\r\n\t\t\t\t\t\t\t<label class=\"form-check form-check-custom mb-0\">\r\n\t\t\t\t\t\t\t\t<input type=\"checkbox\" class=\"form-check-input IsIncludeSaleVat\" id=\"PriceTax\" value=\"false\" />\r\n\t\t\t\t\t\t\t\t<span class=\"form-check-label text-nowrap\">Prices do not include VAT</span>\r\n\t\t\t\t\t\t\t</label>\r\n\r\n\t\t\t\t\t\t\t<label class=\"form-check form-check-custom mb-0\" style=\"display:\">\r\n\t\t\t\t\t\t\t\t<input id=\"IsApplyCostVat\" name=\"IsApplyCostVat\" type=\"checkbox\" class=\"form-check-input IsApplyCostVat\" value=\"0\">\r\n\t\t\t\t\t\t\t\t<span class=\"form-check-label\">Don&#x27;t apply VAT to cost</span>\r\n\t\t\t\t\t\t\t</label>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n\t<!-- end trip -->\r\n\r\n\t<div class=\"text-end mt-2\" id=\"add-trip-div\">\r\n\t\t<a id=\"add-trip-btn\" class=\"btn btn-link py-0\"><i class=\"fa fa-plus me-1\"></i>Add</a>\r\n\t</div>\r\n\r\n</div>\r\n<!---End of Transportation-------------------->\r\n\r\n\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"panel my-3 accordion accordion-icon-toggle reservation-main-accordion\" id=\"kt_accordion_extraDetails\">\r\n\t\t\t\t\t<div class=\"panel-header text-primary accordion-header d-flex \">\r\n\t\t\t\t\t\t<button class=\"btn btn-link p-0 collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#kt_accordion_extraDetails_items\" aria-expanded=\"false\" aria-controls=\"kt_accordion_extraDetails_items\">\r\n\t\t\t\t\t\t\t<span class=\"accordion-icon collapsed d-inline-block\"><span class=\"svg-icon svg-icon-4 \"> <i class=\" fa fa-caret-down text-primary\"></i></span></span>\r\n\t\t\t\t\t\t\tReservation extra details\r\n\t\t\t\t\t\t</button>\r\n\r\n\t\t\t\t\t</div>\r