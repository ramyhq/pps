px-3 py-3\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"input-group header-input-group\">\r\n\t\t\t\t\t\t\t\t\t\t\t<input id=\"MobileSearchTxt\" type=\"text\" class=\"form-control\" placeholder=\"Res. ID, conf., or voucher\" />\r\n\t\t\t\t\t\t\t\t\t\t\t<button class=\"btn btn-outline-secondary\" type=\"button\" id=\"MobileSearchBtn\" title=\"Search\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<em class=\"fa fa-search\"></em>\r\n\t\t\t\t\t\t\t\t\t\t\t</button>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<!--end::Search for reservation for mobile-->\r\n\t\t\t\t\t\t<!--Create reservation-->\r\n\t\t\t\t\t\t                             <div class=\"dropdown d-flex align-items-center ms-1 ms-lg-3 \">\r\n        <button type=\"button\" class=\"btn btn-icon btn-active-light-primary fs-4 w-30px h-30px w-md-40px h-md-40px\" title=\"Create reservation\"\r\n                                 data-bs-toggle=\"dropdown\" aria-expanded=\"false\">\r\n                                    <span class=\"svg-icon\">\r\n                                        <em class=\"fas fa-calendar-plus\"></em>\r\n                                    </span> \r\n                                </button>\r\n                                <ul class=\"dropdown-menu\" aria-labelledby=\"dropdownMenuButton1\">\r\n                <li><a class=\"dropdown-item btn btn-active-light-primary py-1   fs-6\" href=\"/App/Reservations/CreateOrEditRequestReservation?rms=TklhTEVrQzFFM3hySjNNTW9VWDNMUT09\"><i class=\"fa-solid fa-hotel text-muted me-2\"></i>Reservation request</a></li>\r\n                <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEdit?rms=TklhTEVrQzFFM3hySjNNTW9VWDNMUT09\"><i class=\"fa-solid fa-hotel text-muted me-2\"></i>Normal reservation</a></li>\r\n            <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEdit?rms=bCtkcHVYSGU2SzhPV1V1eXFoT0d1UT09\"><i class=\"fa-solid fa-hotel text-muted me-2\"></i>SA reservation</a></li>\r\n                <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEdit?rms=SnpjaTV6a0xjZTFvNkVPbW5wMkllQT09\"><i class=\"fa-solid fa-hotel text-muted me-2\"></i>Hotel direct reservation</a></li>\r\n                <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEdit?rms=aEZJWW50Nk5nT1pLMVEzMWxVTkRGZz09\"><i class=\"fa-solid fa-hotel text-muted me-2\"></i>Agent direct reservation</a></li>\r\n                <li><hr class=\"dropdown-divider \"></li>\r\n                <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEditExtraService\"><i class=\"fa-solid fa-cart-plus text-muted me-2\"></i>General service</a></li>\r\n                    <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEditTransportationService\"><i class=\"fa-solid fa-bus text-muted me-2\"></i>Transportation</a></li>\r\n                    <li><a class=\"dropdown-item  btn btn-active-light-primary py-1 fs-6\" href=\"/App/Reservations/CreateOrEditFlightService\"><i class=\"fa-solid fa-plane text-muted me-2\"></i>Flight</a></li>\r\n                                </ul>\r\n                            </div>\r\n \r\n\r\n\t\t\t\t\t\t<!--End of Create reservation-->\r\n\t\t\t\t\t\t<!--Check Hotel Availability-->\r\n\t\t\t\t\t\t\t<div class=\"d-flex align-items-center ms-1 ms-lg-3\">\r\n\t\t<button type=\"button\" id=\"CheckAvailabilityForDashboardbtn\" class=\"btn btn-icon btn-active-light-primary fs-4 w-30px h-30px w-md-40px h-md-40px\" title=\"Check rooms availability\">\r\n\t\t\t<span class=\"svg-icon\">\r\n\t\t\t\t<em class=\"icomoon-search-building\"> </em>\r\n\t\t\t</span>\r\n\t\t</button>\r\n\t</div>\r\n\r\n\r\n\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t\r\n\r\n\t\t\t\t\t\t\r\n\r\n\t\t\t\t\t\t<style>\r\n    .set-notification-as-read:before{\r\n        content: \"\\2022\";\r\n        padding-right: 0.5rem;\r\n        color:#B5B5C3 !important\r\n     }\r\n</style>\r\n<div class=\"d-flex align-items-center ms-1 ms-lg-3\">\r\n    <div class=\"dropdown\" id=\"header_notification_bar\">\r\n    </div>\r\n</div>\r\n<script id=\"headerNotificationBarTemplate\" type=\"x-tmpl-mustache\">\r\n    <div class=\"topbar-item\" data-bs-toggle=\"dropdown\" data-offset=\"30px,0px\" aria-expanded=\"true\">\r\n        <button class=\"btn btn-icon btn-active-light-primary position-relative w-30px h-30px w-md-40px h-md-40px\">\r\n            {{#unreadCount}}\r\n            <i class=\"flaticon-alert-2 unread-notification fs-2\"></i>\r\n            <span class=\"position-absolute top-0 start-100 translate-middle  badge badge-circle badge-warning unread-notification-count\">\r\n                {{unreadCount}}\r\n            </span>\r\n            {{/unreadCount}}\r\n            {{^unreadCount}}\r\n            <i class=\"flaticon-alarm\"></i>\r\n            {{/unreadCount}}\r\n        </button>\r\n    </div>\r\n    <div class=\"dropdown-menu p-0 m-0 dropdown-menu-fit dropdown-menu-right dropdown-menu-anim dropdown-menu-top-unround dropdown-menu-lg\">\r\n        <div class=\"d-flex flex-column pt-5 bgi-size-cover bgi-no-repeat rounded-top bg-primary\" style=\"min-height: 70px;\">\r\n            <h4 class=\"d-flex\" style=\"align-items:center;justify-content: space-between;\">\r\n                <div class=\"ms-5\">               \r\n                    <span class=\"text-white\">Notifications</span>\r\n                    <span class=\"btn btn-text btn-secondary btn-sm fw-bold btn-font-md ml-2\">{{unreadCount}} New</span>\r\n                 </div>\r\n                <a href=\"javascript:;\" id=\"openNotificationSettingsModalLink\" class=\"btn btn-md btn-icon btn-secondary me-5\">\r\n                    <i class=\"flaticon2-gear\"></i>\r\n                </a>      \r\n            </h4>\r\n           \r\n        </div>\r\n        <div class=\"px-4\">       \r\n            <div class=\"scroll pt-5\" data-scroll=\"true\" data-height=\"300\" data-mobile-height=\"200\" style=\"height: 300px; overflow: hidden;\">\r\n                {{#notifications}}\r\n                <div class=\"d-flex align-items-sm-center mb-7 {{#url}}user-notification-item-clickable{{/url}} {{#isUnread}}user-notification-item-unread{{/isUnread}}\" data-url=\"{{url}}\">\r\n                    <div class=\"symbol symbol-50px me-5\">\r\n                        <span class=\"symbol-label\">\r\n                            <i class=\"{{icon}} {{iconFontClass}} icon-lg\"></i>\r\n                        </span>\r\n                    </div>\r\n                    <div class=\"d-flex align-items-center flex-row-fluid flex-wrap\">\r\n                        <div class=\"flex-grow-1 me-2\">\r\n                            <a class=\" text-hover-primary fs-6 fw-bolder {{^isUnread}}text-muted{{/isUnread}}\">\r\n                                {{text}}\r\n                            </a>\r\n                        </div>\r\n                        {{#isUnread}}\r\n                            <span class=\"text-muted fw-bold d-block fs-7\">\r\n                                {{timeAgo}}\r\n                            </span>\r\n                            <span data-notification-id=\"{{userNotificationId}}\" class=\"btn btn-link-success text-success set-notification-as-read fs-7 py-0 my-0 set-notification-as-read\">\r\n                                Set as read\r\n                            </span>\r\n                        {{/isUnread}}\r\n                    </div>\r\n                </div>\r\n                {{/notifications}}\r\n                {{^notifications.length}}\r\n                <div class=\"notification-empty-text text-center p-5\">\r\n                    There are no notifications.\r\n                </div>\r\n                {{/notifications.length}}\r\n            </div>\r\n            {{#notifications.length}}\r\n            <div class=\"m-1 mb-4 d-flex\" style=\"align-items:center;justify-content: space-between;\">\r\n                {{#unreadCount}}\r\n                    <a class=\"btn btn-secondary col col-xs-12\" href=\"\" id=\"setAllNotificationsAsReadLink\">Set all as read</a>\r\n                    <a class=\"btn btn-primary col col-xs-12\" href=\"/App/Notifications\">See all notifications</a>        \r\n                {{/unreadCount}}\r\n             {{^unreadCount}}\r\n                    <a class=\"btn btn-primary col\" href=\"/App/Notifications\">See all notifications</a>       \r\n             {{/unreadCount}}\r\n            </div>\r\n            {{/notifications.length}}\r\n        </div>\r\n    </div>\r\n</script>\r\n\r\n\t\t\t\t\t\t    <div id=\"chat_is_connecting_icon\" class=\"d-flex align-items-center ms-1 ms-lg-3\">\r\n        <button class=\"btn btn-icon btn-active-light-primary position-relative w-30px h-30px w-md-40px h-md-40px\">\r\n            <img src=\"/Common/Images/loading.gif\" style=\"width: 23px;\" tooltip=\"Chat is connecting...\" placement=\"left\"/>\r\n        </button>\r\n    </div>\r\n    <div id=\"kt_drawer_chat_toggle\" class=\"d-flex align-items-center ms-1 ms-lg-3 d-none\">\r\n        <button class=\"btn btn-icon btn-active-light-primary position-relative w-30px h-30px w-md-40px h-md-40px\">\r\n            <div id=\"chatIconUnRead\" class=\"d-none d-flex\">\r\n                <i class=\"flaticon-chat-2 fs-2 unread-notification\"></i>\r\n                <span class=\"position-absolute top-0 start-100 translate-middle  badge badge-circle badge-warning unread-chat-message-count\">\r\n                    {{unreadChatMessageCount}}\r\n                </span>\r\n            </div>\r\n            <div id=\"chatIcon\">\r\n                <i class=\"flaticon-chat-2 fs-2\"></i>\r\n            </div>\r\n        </button>\r\n    </div>\r\n\r\n\r\n\t\t\t\t\t\t\r\n<div class=\"d-flex ali