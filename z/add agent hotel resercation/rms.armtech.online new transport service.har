" ></i>\r\n                         <i class=\"fas fa-plus-circle fa-stack-1x\"></i>\r\n                    </span>\r\n                    Add attachments</button>\r\n\r\n                    <button type=\"button\" id=\"DownloadMultipleAttachment636\" class=\"btn btn-sm DownloadMultipleAttachment\" disabled=\"disabled\"><em class=\"fa fa-download  my-1\"></em> Download attachments</button>\r\n                    <button type=\"button\" id=\"DeleteMultipleAttachment208\" class=\"btn btn-sm text-danger DeleteMultipleAttachment\" disabled=\"disabled\"><em class=\"fa fa-trash  my-1\"></em> Delete attachments</button>\r\n            <input  type=\"hidden\" id=\"viewonly\"/>\r\n      </div>\r\n    </div>\r\n\r\n   \r\n        <table id=\"AttachmentTable694\" data-filesize=\"15000000\" data-allowedfiles=\"jpeg,tiff,gif,bmp,jfif,jpg,png,pdf,doc,docx,ppt,pptx,mp4,mp3\" data-actions=\"1,3,5,2,4\" data-isCreate=\"True\" data-refrenceId=\"\" data-attachmentType=\"TransportationService\" class=\"table table-separate table-head-custom dataTable no-footer dtr-inline dt-responsive nowrap AttachmentTable\">\r\n            <thead>\r\n                <tr>\r\n                   \r\n            \r\n                              <th>\r\n                            <input type=\"checkbox\" class=\"form-check-input selectAll\" id=\"selectAll476\" />\r\n                        </th>\r\n                         \r\n                    <th>File</th>\r\n                    <th>File name</th>\r\n                    <th class=\"d-none\">Is default attachment</th>\r\n                    <th>Actions</th>\r\n                   \r\n                </tr>\r\n            </thead>\r\n        </table>\r\n    </div>\r\n</div>\r\n<script src=\"/view-resources/areas/app/views/attachment/attachment.js\"></script>\r\n\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div id=\"div_Actions\" class=\"card-footer text-end\">\r\n\r\n\t\t\t\t<button type=\"button\" id=\"SaveBtn\" class=\"btn btn-succe